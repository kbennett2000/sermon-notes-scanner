<?xml version="1.0" encoding="utf-8"?>
<!--
  FR #72 — semi-transparent dark circular scrim used as background for overlay action
  buttons placed on top of image previews (e.g. the Re-Edit button on document_preview).
  Mirrors the visual style of the filmstrip thumbnail "X" close button so users recognize
  the affordance.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#99000000" />
</shape>
