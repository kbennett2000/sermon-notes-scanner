<?xml version="1.0" encoding="utf-8"?>
<!--
  FR #72 — Dark-mode variant of the overlay action button scrim.
  In Dark Mode previews tend to be darker, so a black scrim becomes invisible.
  Use a light, semi-transparent scrim with a subtle white stroke to keep the
  white-tinted icon readable on both bright and dark previews.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#B3424242" />
    <stroke
        android:width="1dp"
        android:color="#80FFFFFF" />
</shape>
